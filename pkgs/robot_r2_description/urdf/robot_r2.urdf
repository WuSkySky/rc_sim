    <parent link="guide_support_mr"/>
    <child link="guide_wheel_mr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- Drive Lift Rods: 4 x box, 15mm x 15mm x 520mm             -->
  <!-- Connected to base using prismatic joints                  -->
  <!-- Initial state: rod top protrudes above chassis            -->
  <!-- Stroke end: rod top becomes flush with chassis top        -->
  <!-- ========================================================= -->


  <!-- drive lift rod front left -->
  <link name="drive_lift_fl">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_fl_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_fl"/>
    <origin xyz="0.210 0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod front right -->
  <link name="drive_lift_fr">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_fr_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_fr"/>
    <origin xyz="0.210 -0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod rear left -->
  <link name="drive_lift_rl">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_rl_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_rl"/>
    <origin xyz="-0.210 0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod rear right -->
  <link name="drive_lift_rr">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_rr_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_rr"/>
    <origin xyz="-0.210 -0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- Drive Wheels: 4 x cylinder, radius = 75mm, length = 80mm  -->
  <!-- Fixed to bottom end of each drive lift rod                -->
  <!-- ========================================================= -->

  <link name="drive_wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_fl_joint" type="fixed">
    <parent link="drive_lift_fl"/>
    <child link="drive_wheel_fl"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <link name="drive_wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_fr_joint" type="fixed">
    <parent link="drive_lift_fr"/>
    <child link="drive_wheel_fr"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <link name="drive_wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
