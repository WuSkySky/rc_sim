<?xml version="1.0"?>
<robot name="simple_chassis_robot">

  <!-- ================= Materials ================= -->

  <material name="gray">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>

  <material name="dark_gray">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.1 0.3 0.9 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>


  <!-- ================= Base Chassis ================= -->
  <!-- 700mm x 468mm x 20mm -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.700 0.468 0.020"/>
      </geometry>
      <material name="Gazebo/Grey"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.700 0.468 0.020"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia
        ixx="0.1463" ixy="0" ixz="0"
        iyy="0.3269" iyz="0"
        izz="0.4727"/>
    </inertial>
  </link>

  <!-- ================= Direction Arrow ================= -->

  <link name="direction_arrow">
    <visual>
      <origin xyz="0.265 0.0 0.014" rpy="0 0 0"/>
      <geometry>
        <box size="0.110 0.022 0.003"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0.318 0.017 0.014" rpy="0 0 -0.78539816339"/>
      <geometry>
        <box size="0.067 0.020 0.003"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0.318 -0.017 0.014" rpy="0 0 0.78539816339"/>
      <geometry>
        <box size="0.067 0.020 0.003"/>
      </geometry>
    </visual>
  </link>

  <joint name="direction_arrow_joint" type="fixed">
    <parent link="base_link"/>
    <child link="direction_arrow"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Guide Wheel Supports: 6 x box, 20mm x 20mm x 170mm        -->
  <!-- Position: 4 corners + middle of two long sides            -->
  <!-- Base bottom z = -0.01, support center z = -0.095          -->
  <!-- ========================================================= -->

  <!-- front left corner guide support -->
  <link name="guide_support_fl">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_fl"/>
    <origin xyz="0.340 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- front right corner guide support -->
  <link name="guide_support_fr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_fr"/>
    <origin xyz="0.340 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- rear left corner guide support -->
  <link name="guide_support_rl">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_rl"/>
    <origin xyz="-0.340 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- rear right corner guide support -->
  <link name="guide_support_rr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_rr"/>
    <origin xyz="-0.340 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle left long-side guide support -->
  <link name="guide_support_ml">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_ml_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_ml"/>
    <origin xyz="-0.080 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle right long-side guide support -->
  <link name="guide_support_mr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_mr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_mr"/>
    <origin xyz="-0.080 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Guide Wheels: 6 x cylinder, radius = 19mm, length = 17mm -->
  <!-- Wheel center at bottom end of each guide support          -->
  <!-- ========================================================= -->

  <link name="guide_wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_fl_joint" type="fixed">
    <parent link="guide_support_fl"/>
    <child link="guide_wheel_fl"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
