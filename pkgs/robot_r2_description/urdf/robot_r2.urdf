    <parent link="guide_support_fr"/>
    <child link="guide_wheel_fr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_rl_joint" type="fixed">
    <parent link="guide_support_rl"/>
    <child link="guide_wheel_rl"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_rr_joint" type="fixed">
    <parent link="guide_support_rr"/>
    <child link="guide_wheel_rr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_ml">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
