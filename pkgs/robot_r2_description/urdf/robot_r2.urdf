  <!-- ================= Gazebo Plugins ================= -->

  <gazebo>
    <plugin name="robot_r2_planar_move" filename="librobot_r2_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/cmd_vel</command_topic>
      <velocity_feedback_topic>/r2/velocity_feedback</velocity_feedback_topic>
      <cmd_vel_timeout>0.25</cmd_vel_timeout>
      <x_velocity_p_gain>150.0</x_velocity_p_gain>
      <y_velocity_p_gain>150.0</y_velocity_p_gain>
      <x_velocity_i_gain>80.0</x_velocity_i_gain>
      <y_velocity_i_gain>80.0</y_velocity_i_gain>
      <max_integral_force>120.0</max_integral_force>
      <yaw_velocity_p_gain>20.0</yaw_velocity_p_gain>
      <max_x_velocity>10.0</max_x_velocity>
      <max_y_velocity>10.0</max_y_velocity>
      <max_yaw_velocity>15.7</max_yaw_velocity>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="robot_r2_localizer" filename="librobot_r2_localizer.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <pose_topic>/r2/pose_feedback</pose_topic>
      <link_name>base_link</link_name>
      <pose_offset>0 0 0 0 0 0</pose_offset>
      <frame_id>world</frame_id>
      <publish_rate>50.0</publish_rate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="robot_r2_lift_controller" filename="librobot_r2_lift_controller.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/lift/cmd_lift</command_topic>
      <position_feedback_topic>/r2/lift/position_feedback</position_feedback_topic>
      <drive_fl_joint_name>drive_lift_fl_joint</drive_fl_joint_name>
      <drive_fr_joint_name>drive_lift_fr_joint</drive_fr_joint_name>
      <drive_rl_joint_name>drive_lift_rl_joint</drive_rl_joint_name>
      <drive_rr_joint_name>drive_lift_rr_joint</drive_rr_joint_name>
      <min_lift>0.0</min_lift>
      <max_lift>0.376</max_lift>
    </plugin>
  </gazebo>

</robot>
