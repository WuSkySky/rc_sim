<?xml version="1.0"?>
<robot name="simple_chassis_robot">

  <!-- ================= Materials ================= -->

  <material name="gray">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>

  <material name="dark_gray">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.1 0.3 0.9 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>


  <!-- ================= Base Chassis ================= -->
  <!-- 700mm x 468mm x 20mm -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.700 0.468 0.020"/>
      </geometry>
      <material name="Gazebo/Grey"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.700 0.468 0.020"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia
        ixx="0.1463" ixy="0" ixz="0"
        iyy="0.3269" iyz="0"
        izz="0.4727"/>
    </inertial>
  </link>

  <!-- ================= Direction Arrow ================= -->

  <link name="direction_arrow">
    <visual>
      <origin xyz="0.265 0.0 0.014" rpy="0 0 0"/>
      <geometry>
        <box size="0.110 0.022 0.003"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0.318 0.017 0.014" rpy="0 0 -0.78539816339"/>
      <geometry>
        <box size="0.067 0.020 0.003"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0.318 -0.017 0.014" rpy="0 0 0.78539816339"/>
      <geometry>
        <box size="0.067 0.020 0.003"/>
      </geometry>
    </visual>
  </link>

  <joint name="direction_arrow_joint" type="fixed">
    <parent link="base_link"/>
    <child link="direction_arrow"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Vertical Bars: 20x20x550mm, x=0 center, y=±0.19 (38cm)    -->
  <!-- ========================================================= -->

  <link name="vertical_bar_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.005" ixy="0" ixz="0"
               iyy="0.005" iyz="0"
               izz="0.00003"/>
    </inertial>
  </link>

  <joint name="vertical_bar_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="vertical_bar_left"/>
    <origin xyz="0 0.190 0.285" rpy="0 0 0"/>
  </joint>

  <link name="vertical_bar_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.005" ixy="0" ixz="0"
               iyy="0.005" iyz="0"
               izz="0.00003"/>
    </inertial>
  </link>

  <joint name="vertical_bar_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="vertical_bar_right"/>
    <origin xyz="0 -0.190 0.285" rpy="0 0 0"/>
  </joint>

  <!-- rear vertical bar: x=-0.18 center -->
  <link name="vertical_bar_rear">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.550"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.005" ixy="0" ixz="0"
               iyy="0.005" iyz="0"
               izz="0.00003"/>
    </inertial>
  </link>

  <joint name="vertical_bar_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="vertical_bar_rear"/>
    <origin xyz="-0.190 0 0.285" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Bar Mount: tiny invisible link, base→mount(prismatic z)   -->
  <!-- ========================================================= -->

  <link name="bar_mount">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 0.010"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.010 0.010"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>
  </link>

  <joint name="bar_mount_prismatic_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="bar_mount"/>
    <origin xyz="0.2925 0 0.260" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.180" upper="0.240" effort="100" velocity="0.2"/>
    <dynamics damping="10.0" friction="2.0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Long Bar: 20x20x428mm, center at y=0 (chassis centerline) -->
  <!-- Revolute on bar_mount (y-axis), ±90° rotation             -->
  <!-- ========================================================= -->

  <link name="long_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.428 0.020"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.428 0.020"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.16"/>
      <inertia ixx="0.00245" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.00245"/>
    </inertial>
  </link>

  <joint name="long_bar_revolute_joint" type="revolute">
    <parent link="bar_mount"/>
    <child link="long_bar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="0" effort="100" velocity="3.0"/>
    <dynamics damping="5.0" friction="0.5"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Grippers: 2 plates, symmetric, slide along bar (y-axis)   -->
  <!-- Size 5×1×20cm, hang down from bar, start at ends → center -->
  <!-- ========================================================= -->

  <!-- left gripper (y>0) -->
  <link name="gripper_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.01 0.20"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.01 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>
  </link>

  <joint name="gripper_left_joint" type="prismatic">
    <parent link="long_bar"/>
    <child link="gripper_left"/>
    <origin xyz="0.1175 0.209 -0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.209" upper="0" effort="50" velocity="0.3"/>
    <dynamics damping="10.0" friction="2.0"/>
  </joint>

  <!-- right gripper (y<0) -->
  <link name="gripper_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.01 0.20"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.10 0.01 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0005" ixy="0" ixz="0"
               iyy="0.0005" iyz="0"
               izz="0.0005"/>
    </inertial>
  </link>

  <joint name="gripper_right_joint" type="prismatic">
    <parent link="long_bar"/>
    <child link="gripper_right"/>
    <origin xyz="0.1175 -0.209 -0.030" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.209" effort="50" velocity="0.3"/>
    <dynamics damping="10.0" friction="2.0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- Guide Wheel Supports: 8 x box, 20mm x 20mm x 170mm        -->
  <!-- Position: 4 corners + middle of two long sides            -->
  <!-- Base bottom z = -0.01, support center z = -0.095          -->
  <!-- ========================================================= -->

  <!-- front left corner guide support -->
  <link name="guide_support_fl">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_fl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_fl"/>
    <origin xyz="0.340 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- front right corner guide support -->
  <link name="guide_support_fr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_fr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_fr"/>
    <origin xyz="0.340 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- front center guide support -->
  <link name="guide_support_fc">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_fc_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_fc"/>
    <origin xyz="0.340 0 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- rear left corner guide support -->
  <link name="guide_support_rl">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_rl_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_rl"/>
    <origin xyz="-0.340 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- rear right corner guide support -->
  <link name="guide_support_rr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_rr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_rr"/>
    <origin xyz="-0.340 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle left long-side guide support -->
  <link name="guide_support_ml">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_ml_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_ml"/>
    <origin xyz="-0.080 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle front left long-side guide support -->
  <link name="guide_support_ml2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_ml2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_ml2"/>
    <origin xyz="0.080 0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle front right long-side guide support -->
  <link name="guide_support_mr2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_mr2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_mr2"/>
    <origin xyz="0.080 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- middle right long-side guide support -->
  <link name="guide_support_mr">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.020 0.020 0.170"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.000122" ixy="0" ixz="0"
               iyy="0.000122" iyz="0"
               izz="0.00000333"/>
    </inertial>
  </link>

  <joint name="guide_support_mr_joint" type="fixed">
    <parent link="base_link"/>
    <child link="guide_support_mr"/>
    <origin xyz="-0.080 -0.224 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Guide Wheels: 8 x cylinder, radius = 19mm, length = 17mm -->
  <!-- Wheel center at bottom end of each guide support          -->
  <!-- ========================================================= -->

  <link name="guide_wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_fl_joint" type="fixed">
    <parent link="guide_support_fl"/>
    <child link="guide_wheel_fl"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_fr_joint" type="fixed">
    <parent link="guide_support_fr"/>
    <child link="guide_wheel_fr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_rl_joint" type="fixed">
    <parent link="guide_support_rl"/>
    <child link="guide_wheel_rl"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_rr_joint" type="fixed">
    <parent link="guide_support_rr"/>
    <child link="guide_wheel_rr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_ml">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_ml_joint" type="fixed">
    <parent link="guide_support_ml"/>
    <child link="guide_wheel_ml"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_mr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_mr_joint" type="fixed">
    <parent link="guide_support_mr"/>
    <child link="guide_wheel_mr"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_ml2">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_ml2_joint" type="fixed">
    <parent link="guide_support_ml2"/>
    <child link="guide_wheel_ml2"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <link name="guide_wheel_mr2">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.019" length="0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00000229" ixy="0" ixz="0"
               iyy="0.00000361" iyz="0"
               izz="0.00000229"/>
    </inertial>
  </link>

  <joint name="guide_wheel_mr2_joint" type="fixed">
    <parent link="guide_support_mr2"/>
    <child link="guide_wheel_mr2"/>
    <origin xyz="0 0 -0.085" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- Drive Lift Rods: 4 x box, 15mm x 15mm x 520mm             -->
  <!-- Connected to base using prismatic joints                  -->
  <!-- Initial state: rod top protrudes above chassis            -->
  <!-- Stroke end: rod top becomes flush with chassis top        -->
  <!-- ========================================================= -->


  <!-- drive lift rod front left -->
  <link name="drive_lift_fl">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_fl_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_fl"/>
    <origin xyz="0.210 0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod front right -->
  <link name="drive_lift_fr">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_fr_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_fr"/>
    <origin xyz="0.210 -0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod rear left -->
  <link name="drive_lift_rl">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_rl_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_rl"/>
    <origin xyz="-0.210 0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- drive lift rod rear right -->
  <link name="drive_lift_rr">
    <visual>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.520"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.260" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.00338" ixy="0" ixz="0"
               iyy="0.00338" iyz="0"
               izz="0.00000563"/>
    </inertial>
  </link>

  <joint name="drive_lift_rr_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="drive_lift_rr"/>
    <origin xyz="-0.210 -0.2415 0.396" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.376" effort="1000" velocity="0.2"/>
    <dynamics damping="5.0" friction="1.0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- Drive Wheels: 4 x cylinder, radius = 75mm, length = 80mm  -->
  <!-- Fixed to bottom end of each drive lift rod                -->
  <!-- ========================================================= -->

  <link name="drive_wheel_fl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_fl_joint" type="fixed">
    <parent link="drive_lift_fl"/>
    <child link="drive_wheel_fl"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <link name="drive_wheel_fr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_fr_joint" type="fixed">
    <parent link="drive_lift_fr"/>
    <child link="drive_wheel_fr"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <link name="drive_wheel_rl">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_rl_joint" type="fixed">
    <parent link="drive_lift_rl"/>
    <child link="drive_wheel_rl"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <link name="drive_wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_rr_joint" type="fixed">
    <parent link="drive_lift_rr"/>
    <child link="drive_wheel_rr"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <!-- ================= Gazebo Settings ================= -->

  <gazebo reference="base_link">
    <self_collide>false</self_collide>
    <material>Gazebo/Grey</material>
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>1000000.0</kp>
    <kd>1000.0</kd>
  </gazebo>

  <gazebo reference="direction_arrow">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="guide_wheel_fl">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_fr">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_rl">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_rr">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_ml">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_mr">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_ml2">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_mr2">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="gripper_left">
    <material>Gazebo/DarkGrey</material>
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>100000000.0</kp>
    <kd>1000.0</kd>
  </gazebo>

  <gazebo reference="gripper_right">
    <material>Gazebo/DarkGrey</material>
    <mu1>1000.0</mu1>
    <mu2>1000.0</mu2>
    <kp>100000000.0</kp>
    <kd>1000.0</kd>
  </gazebo>

  <gazebo reference="drive_wheel_fl">
    <material>Gazebo/Black</material>
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
  </gazebo>

  <gazebo reference="drive_wheel_fr">
    <material>Gazebo/Black</material>
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
  </gazebo>

  <gazebo reference="drive_wheel_rl">
    <material>Gazebo/Black</material>
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
  </gazebo>

  <gazebo reference="drive_wheel_rr">
    <material>Gazebo/Black</material>
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
  </gazebo>

  <!-- ================= Camera Sensor ================= -->

  <gazebo reference="base_link">
    <sensor name="camera" type="camera">
      <pose>0.35 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>
      <camera>
        <horizontal_fov>1.9199</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>50.0</far>
        </clip>
      </camera>
      <plugin name="front_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/r2</namespace>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>base_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================= Gazebo Plugins ================= -->

  <gazebo>
    <plugin name="robot_r2_planar_move" filename="librobot_r2_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/cmd_vel</command_topic>
      <velocity_feedback_topic>/r2/velocity_feedback</velocity_feedback_topic>
      <cmd_vel_timeout>0.25</cmd_vel_timeout>
      <x_velocity_p_gain>150.0</x_velocity_p_gain>
      <y_velocity_p_gain>150.0</y_velocity_p_gain>
      <x_velocity_i_gain>80.0</x_velocity_i_gain>
      <y_velocity_i_gain>80.0</y_velocity_i_gain>
      <max_integral_force>120.0</max_integral_force>
      <yaw_velocity_p_gain>20.0</yaw_velocity_p_gain>
      <max_x_velocity>10.0</max_x_velocity>
      <max_y_velocity>10.0</max_y_velocity>
      <max_yaw_velocity>15.7</max_yaw_velocity>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="robot_r2_localizer" filename="librobot_r2_localizer.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <pose_topic>/r2/pose_feedback</pose_topic>
      <link_name>base_link</link_name>
      <pose_offset>0 0 0 0 0 0</pose_offset>
      <frame_id>world</frame_id>
      <publish_rate>50.0</publish_rate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="robot_r2_lift_controller" filename="librobot_r2_lift_controller.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/lift/cmd_lift</command_topic>
      <position_feedback_topic>/r2/lift/position_feedback</position_feedback_topic>
      <drive_fl_joint_name>drive_lift_fl_joint</drive_fl_joint_name>
      <drive_fr_joint_name>drive_lift_fr_joint</drive_fr_joint_name>
      <drive_rl_joint_name>drive_lift_rl_joint</drive_rl_joint_name>
      <drive_rr_joint_name>drive_lift_rr_joint</drive_rr_joint_name>
      <min_lift>0.0</min_lift>
      <max_lift>0.376</max_lift>
    </plugin>
  </gazebo>

  <!-- ================= Bar Lift Controller ================= -->
  <gazebo>
    <plugin name="robot_r2_bar_lift" filename="librobot_r2_bar_lift.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/gripper/lift_cmd</command_topic>
      <feedback_topic>/r2/gripper/lift_feedback</feedback_topic>
      <joint_name>bar_mount_prismatic_joint</joint_name>
      <min_position>-0.180</min_position>
      <max_position>0.240</max_position>
    </plugin>
  </gazebo>

  <!-- ================= Bar Rotate Controller ================= -->
  <gazebo>
    <plugin name="robot_r2_bar_rotate" filename="librobot_r2_bar_rotate.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/gripper/rotate_cmd</command_topic>
      <feedback_topic>/r2/gripper/rotate_feedback</feedback_topic>
      <joint_name>long_bar_revolute_joint</joint_name>
      <min_position>-3.14159</min_position>
      <max_position>0.0</max_position>
    </plugin>
  </gazebo>

  <!-- ================= Gripper Controller ================= -->
  <gazebo>
    <plugin name="robot_r2_gripper" filename="librobot_r2_gripper.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/gripper/grip_cmd</command_topic>
      <feedback_topic>/r2/gripper/grip_feedback</feedback_topic>
      <gap_feedback_topic>/r2/gripper/grip_gap_feedback</gap_feedback_topic>
      <left_joint_name>gripper_left_joint</left_joint_name>
      <right_joint_name>gripper_right_joint</right_joint_name>
      <stroke>0.209</stroke>
    </plugin>
  </gazebo>

</robot>
