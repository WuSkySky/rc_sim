  <link name="drive_wheel_rr">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.080"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.20"/>
      <inertia ixx="0.000649" ixy="0" ixz="0"
               iyy="0.000563" iyz="0"
               izz="0.000649"/>
    </inertial>
  </link>

  <joint name="drive_wheel_rr_joint" type="fixed">
    <parent link="drive_lift_rr"/>
    <child link="drive_wheel_rr"/>
    <origin xyz="0 0 -0.520" rpy="0 0 0"/>
  </joint>


  <!-- ================= Gazebo Settings ================= -->

  <gazebo reference="base_link">
    <self_collide>false</self_collide>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="direction_arrow">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="guide_wheel_fl">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_fr">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_rl">
    <material>Gazebo/Black</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>

  <gazebo reference="guide_wheel_rr">
