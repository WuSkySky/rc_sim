<?xml version="1.0"?>
<sdf version="1.6">
  <model name="robot_r2">
    <static>false</static>

    <plugin name="robot_r2_planar_move" filename="librobot_r2_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/simulation/r2/cmd_vel</command_topic>
      <velocity_feedback_topic>/simulation/r2/velocity_feedback</velocity_feedback_topic>
      <cmd_vel_timeout>0.25</cmd_vel_timeout>
      <x_velocity_p_gain>80.0</x_velocity_p_gain>
      <y_velocity_p_gain>80.0</y_velocity_p_gain>
      <x_velocity_i_gain>40.0</x_velocity_i_gain>
      <y_velocity_i_gain>40.0</y_velocity_i_gain>
      <max_integral_force>35.0</max_integral_force>
      <yaw_velocity_p_gain>20.0</yaw_velocity_p_gain>
      <max_x_velocity>10.0</max_x_velocity>
      <max_y_velocity>10.0</max_y_velocity>
      <max_yaw_velocity>15.7</max_yaw_velocity>
    </plugin>

    <plugin name="robot_r2_localizer" filename="librobot_r2_localizer.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <position_topic>/simulation/r2/position_feedback</position_topic>
      <link_name>base_link</link_name>
      <pose_offset>0 0 0 0 0 0</pose_offset>
      <frame_id>world</frame_id>
      <publish_rate>50.0</publish_rate>
    </plugin>

    <link name="base_link">
      <pose>0 0 0.065 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.06042</ixx>
          <iyy>0.00708</iyy>
          <izz>0.06667</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_section_link">
      <pose>0.20 0 0.065 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.04531</ixx>
          <iyy>0.00531</iyy>
          <izz>0.05000</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_section_collision">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
      </collision>

      <visual name="front_section_visual">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_section_link">
      <pose>-0.20 0 0.065 0 0 0</pose>
      <inertial>
        <mass>1.5</mass>
        <inertia>
          <ixx>0.04531</ixx>
          <iyy>0.00531</iyy>
          <izz>0.05000</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_section_collision">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
      </collision>

      <visual name="rear_section_visual">
        <geometry>
          <box>
            <size>0.20 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_left_mecanum_wheel_link">
      <pose>0.30 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_right_mecanum_wheel_link">
      <pose>0.30 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_left_mecanum_wheel_link">
      <pose>-0.30 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="rear_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_right_mecanum_wheel_link">
      <pose>-0.30 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="rear_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_left_mecanum_wheel_joint" type="fixed">
      <parent>front_section_link</parent>
      <child>front_left_mecanum_wheel_link</child>
    </joint>

    <joint name="front_right_mecanum_wheel_joint" type="fixed">
      <parent>front_section_link</parent>
      <child>front_right_mecanum_wheel_link</child>
    </joint>

    <joint name="rear_left_mecanum_wheel_joint" type="fixed">
      <parent>rear_section_link</parent>
      <child>rear_left_mecanum_wheel_link</child>
    </joint>

    <joint name="rear_right_mecanum_wheel_joint" type="fixed">
      <parent>rear_section_link</parent>
      <child>rear_right_mecanum_wheel_link</child>
    </joint>

    <joint name="front_lift_joint" type="prismatic">
      <parent>base_link</parent>
      <child>front_section_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.30</lower>
          <upper>0.30</upper>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>5.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_lift_joint" type="prismatic">
      <parent>base_link</parent>
      <child>rear_section_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.30</lower>
          <upper>0.30</upper>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>5.0</friction>
        </dynamics>
      </axis>
    </joint>
  </model>
</sdf>
