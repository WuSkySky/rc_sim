<?xml version="1.0"?>
<sdf version="1.6">
  <model name="robot_r2">
    <static>false</static>

    <plugin name="robot_r2_planar_move" filename="librobot_r2_planar_move.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/cmd_vel</command_topic>
      <velocity_feedback_topic>/r2/velocity_feedback</velocity_feedback_topic>
      <cmd_vel_timeout>0.25</cmd_vel_timeout>
      <x_velocity_p_gain>150.0</x_velocity_p_gain>
      <y_velocity_p_gain>150.0</y_velocity_p_gain>
      <x_velocity_i_gain>80.0</x_velocity_i_gain>
      <y_velocity_i_gain>80.0</y_velocity_i_gain>
      <max_integral_force>120.0</max_integral_force>
      <yaw_velocity_p_gain>20.0</yaw_velocity_p_gain>
      <max_x_velocity>10.0</max_x_velocity>
      <max_y_velocity>10.0</max_y_velocity>
      <max_yaw_velocity>15.7</max_yaw_velocity>
    </plugin>

    <plugin name="robot_r2_localizer" filename="librobot_r2_localizer.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <pose_topic>/r2/pose_feedback</pose_topic>
      <link_name>base_link</link_name>
      <pose_offset>0 0 0 0 0 0</pose_offset>
      <frame_id>world</frame_id>
      <publish_rate>50.0</publish_rate>
    </plugin>

    <plugin name="robot_r2_lift_controller" filename="librobot_r2_lift_controller.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <command_topic>/r2/lift/cmd_lift</command_topic>
      <position_feedback_topic>/r2/lift/position_feedback</position_feedback_topic>
      <front_joint_name>front_lift_joint</front_joint_name>
      <rear_joint_name>rear_lift_joint</rear_joint_name>
      <min_lift>-0.30</min_lift>
      <max_lift>0.30</max_lift>
      <position_p_gain>2500.0</position_p_gain>
      <position_i_gain>1600.0</position_i_gain>
      <position_d_gain>400.0</position_d_gain>
      <position_i_max>200.0</position_i_max>
      <position_i_min>-200.0</position_i_min>
      <max_actuation_force>300.0</max_actuation_force>
    </plugin>

    <link name="base_link">
      <pose>0 0 0.065 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.06042</ixx>
          <iyy>0.01542</iyy>
          <izz>0.07500</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.24 0.48 0.04</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.30 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_section_link">
      <pose>0.225 0 0.065 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.03021</ixx>
          <iyy>0.00208</iyy>
          <izz>0.03188</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_section_collision">
        <geometry>
          <box>
            <size>0.12 0.48 0.04</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_section_visual">
        <geometry>
          <box>
            <size>0.15 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>

      <sensor name="camera" type="camera">
        <pose>0.076 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>30.0</update_rate>
        <visualize>false</visualize>
        <camera>
          <horizontal_fov>1.9199</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.02</near>
            <far>50.0</far>
          </clip>
        </camera>
        <plugin name="front_camera_controller" filename="libgazebo_ros_camera.so">
          <ros>
            <namespace>/r2</namespace>
          </ros>
          <camera_name>front_camera</camera_name>
          <frame_name>front_section_link</frame_name>
        </plugin>
      </sensor>
    </link>

    <link name="rear_section_link">
      <pose>-0.225 0 0.065 0 0 0</pose>
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.03021</ixx>
          <iyy>0.00208</iyy>
          <izz>0.03188</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_section_collision">
        <geometry>
          <box>
            <size>0.12 0.48 0.04</size>
          </box>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="rear_section_visual">
        <geometry>
          <box>
            <size>0.15 0.60 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 1.0 1.0</ambient>
          <diffuse>0.1 0.3 1.0 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_left_mecanum_wheel_link">
      <pose>0.30 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_right_mecanum_wheel_link">
      <pose>0.30 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_left_mecanum_wheel_link">
      <pose>-0.30 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="rear_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="rear_right_mecanum_wheel_link">
      <pose>-0.30 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="rear_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="rear_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="middle_front_left_mecanum_wheel_link">
      <pose>0.08 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="middle_front_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="middle_front_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="middle_front_right_mecanum_wheel_link">
      <pose>0.08 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="middle_front_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="middle_front_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="middle_rear_left_mecanum_wheel_link">
      <pose>-0.08 0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="middle_rear_left_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="middle_rear_left_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="middle_rear_right_mecanum_wheel_link">
      <pose>-0.08 -0.30 0.04 0 0 0</pose>
      <inertial>
        <mass>0.4</mass>
        <inertia>
          <ixx>0.00026</ixx>
          <iyy>0.00026</iyy>
          <izz>0.00026</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="middle_rear_right_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.3</mu>
              <mu2>0.3</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="middle_rear_right_wheel_visual">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.02 0.02 0.02 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="front_left_mecanum_wheel_joint" type="fixed">
      <parent>front_section_link</parent>
      <child>front_left_mecanum_wheel_link</child>
    </joint>

    <joint name="front_right_mecanum_wheel_joint" type="fixed">
      <parent>front_section_link</parent>
      <child>front_right_mecanum_wheel_link</child>
    </joint>

    <joint name="rear_left_mecanum_wheel_joint" type="fixed">
      <parent>rear_section_link</parent>
      <child>rear_left_mecanum_wheel_link</child>
    </joint>

    <joint name="rear_right_mecanum_wheel_joint" type="fixed">
      <parent>rear_section_link</parent>
      <child>rear_right_mecanum_wheel_link</child>
    </joint>

    <joint name="middle_front_left_mecanum_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>middle_front_left_mecanum_wheel_link</child>
    </joint>

    <joint name="middle_front_right_mecanum_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>middle_front_right_mecanum_wheel_link</child>
    </joint>

    <joint name="middle_rear_left_mecanum_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>middle_rear_left_mecanum_wheel_link</child>
    </joint>

    <joint name="middle_rear_right_mecanum_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>middle_rear_right_mecanum_wheel_link</child>
    </joint>

    <joint name="front_lift_joint" type="prismatic">
      <parent>base_link</parent>
      <child>front_section_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.30</lower>
          <upper>0.30</upper>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>5.0</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="rear_lift_joint" type="prismatic">
      <parent>base_link</parent>
      <child>rear_section_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.30</lower>
          <upper>0.30</upper>
        </limit>
        <dynamics>
          <damping>20.0</damping>
          <friction>5.0</friction>
        </dynamics>
      </axis>
    </joint>
  </model>
</sdf>
